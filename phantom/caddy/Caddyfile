{
	acme_dns porkbun {
		api_key {env.PORKBUN_API_KEY}
		api_secret_key {env.PORKBUN_API_SECRET_KEY}
	}

	dynamic_dns {
		provider porkbun {
			api_key {env.PORKBUN_API_KEY}
			api_secret_key {env.PORKBUN_API_SECRET_KEY}
		}

		domains {
			{$PORKBUN_DOMAIN} @ * *.ipfs.kubo *.ipns.kubo
		}
	}

	email {env.EMAIL}

	servers {
		trusted_proxies static private_ranges
		trusted_proxies_strict
		strict_sni_host on
	}
}

(anubis) {
	route {
		reverse_proxy /.within.website/* anubis:8923

		forward_auth anubis:8923 {
			uri /.within.website/x/cmd/anubis/api/check
			trusted_proxies private_ranges

			@unauthorized status 401
			handle_response @unauthorized {
				redir * /.within.website/?redir={uri} 307
			}
		}
	}
}

(authentik) {
	route {
		reverse_proxy /outpost.goauthentik.io/* authentik-server:9000

		forward_auth authentik-server:9000 {
			uri /outpost.goauthentik.io/auth/caddy
			copy_headers X-Authentik-Username X-Authentik-Groups X-Authentik-Entitlements X-Authentik-Email X-Authentik-Name X-Authentik-Uid X-Authentik-Jwt X-Authentik-Meta-Jwks X-Authentik-Meta-Outpost X-Authentik-Meta-Provider X-Authentik-Meta-App X-Authentik-Meta-Version Authorization
			trusted_proxies private_ranges
		}
	}
}

(maxmind_geolocation) {
	@maxmind_geolocation {
		not maxmind_geolocation {
			allow_countries {blocks.allow_countries}
			db_path /data/geoip/GeoLite2-Country.mmdb
		}

		not maxmind_geolocation {
			allow_subdivisions {blocks.allow_subdivisions}
			db_path /data/geoip/GeoLite2-City.mmdb
		}
	}

	handle @maxmind_geolocation {
		abort
	}
}

(log) {
	log {args[0]}.{$PORKBUN_DOMAIN} {
		output file /var/log/caddy/{args[0]}.{$PORKBUN_DOMAIN}.log {
			roll_local_time
		}
	}
}

{$PORKBUN_DOMAIN} *.{$PORKBUN_DOMAIN} *.ipfs.kubo.{$PORKBUN_DOMAIN} *.ipns.kubo.{$PORKBUN_DOMAIN} *.kubo.{$PORKBUN_DOMAIN} {
	encode
	header Strict-Transport-Security "max-age=63072000"

	log {$PORKBUN_DOMAIN} {
		output file /var/log/caddy/{$PORKBUN_DOMAIN}.log {
			roll_local_time
		}
	}

	tls {
		alpn h3 h2
		dns porkbun {
			api_key {env.PORKBUN_API_KEY}
			api_secret_key {env.PORKBUN_API_SECRET_KEY}
		}
		protocols tls1.3
		resolvers 2606:4700:4700::1111 1.1.1.1 2606:4700:4700::1001 1.0.0.1 2001:4860:4860::8888 8.8.8.8 2001:4860:4860::8844 8.8.4.4
	}

	@h1 {
		protocol http/1.1
		not header Connection *Upgrade*
		not header User-Agent matrix-authentication-service/*
	}
	handle @h1 {
		header Connection "Upgrade"
		header Upgrade "HTTP/3.0"
		error 426
	}

	import log www
	@www host www.{$PORKBUN_DOMAIN}
	handle @www {
		log_name www
		redir https://{$PORKBUN_DOMAIN}{uri} permanent
	}

	@root host {$PORKBUN_DOMAIN}
	handle @root {
		file_server
		root /var/www/html
	}

	import log anubis
	@anubis host anubis.{$PORKBUN_DOMAIN}
	handle @anubis {
		log_name anubis
		reverse_proxy anubis:8923
	}

	import log authentik
	@authentik host authentik.{$PORKBUN_DOMAIN}
	handle @authentik {
		log_name authentik

		import maxmind_geolocation {
			allow_subdivisions QC
		}

		reverse_proxy authentik-server:9000
	}

	import log backrest
	@backrest host backrest.{$PORKBUN_DOMAIN}
	handle @backrest {
		log_name backrest

		import maxmind_geolocation {
			allow_subdivisions QC
		}
