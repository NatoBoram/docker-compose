# See https://github.com/Chocobozzz/PeerTube/blob/3a5abc909fb20bc18d9dacb9029d1445863fa6a9/support/docker/production/.env

# Database username and password used by PeerTube
PEERTUBE_DB_PASSWORD=

# PeerTube server configuration
PEERTUBE_WEBSERVER_HOSTNAME=
PEERTUBE_SECRET=

# E-mail configuration
PEERTUBE_SMTP_USERNAME=
PEERTUBE_SMTP_PASSWORD=
PEERTUBE_SMTP_HOSTNAME=
PEERTUBE_SMTP_PORT=
PEERTUBE_SMTP_FROM=
PEERTUBE_SMTP_TLS=
PEERTUBE_SMTP_DISABLE_STARTTLS=
PEERTUBE_ADMIN_EMAIL=
